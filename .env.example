# ─── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=              # https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=         # Public anon key from Supabase dashboard
SUPABASE_SERVICE_ROLE_KEY=             # Server-only: webhooks, cron jobs, user deletion

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=                     # sk_live_... or sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=    # pk_live_... or pk_test_...
STRIPE_WEBHOOK_SECRET=                 # whsec_... from Stripe Dashboard > Webhooks
STRIPE_PRICE_PLUS=                     # price_xxx for Plus tier ($9.99/mo)
STRIPE_PRICE_PRO=                      # price_xxx for Pro tier ($24.99/mo)
STRIPE_PRICE_FAMILY=                   # price_xxx for Family tier ($39.99/mo)

# ─── Resend (Email) ──────────────────────────────────────────────────────────
RESEND_API_KEY=                        # re_... from Resend dashboard
RESEND_FROM_EMAIL=                     # Default: HōMI <noreply@homitechnology.com>

# ─── Anthropic (AI Agent + Trinity) ──────────────────────────────────────────
ANTHROPIC_API_KEY=                     # sk-ant-... for Claude API

# ─── Cron ─────────────────────────────────────────────────────────────────────
CRON_SECRET=                           # Shared secret for Vercel Cron auth headers

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=                   # https://app.homitechnology.com (no trailing slash)

# ============================================================================
# HōMI Technology — Environment Variables
# ============================================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local — it is gitignored via the .env* rule.
# ============================================================================

# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Vercel (optional — for deployment tooling)
VERCEL_TOKEN=your-vercel-token

# GitHub (optional — for CI/CD integrations)
GITHUB_PAT=your-github-pat

# Stripe (optional — for payment processing)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...

# Resend (optional — for transactional emails)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@homitechnology.com

# Anthropic (optional — for AI features, falls back to mock)
ANTHROPIC_API_KEY=sk-ant-...

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
